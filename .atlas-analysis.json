  "keyFeatures": [
    "80+ string transformation operations including encoding, hashing, and case conversion",
    "Interactive TUI mode with fuzzy search for discovering operations",
    "Multiple input methods: direct input, file input, piping, and chaining",
    "Cross-platform support for Linux, macOS, Windows, and Termux",
    "Fast streaming processing for large files"
  ],
  "publicApiSurface": [
    "sttr <command> [input]",
    "sttr (interactive mode)",
    "ascii85-encode/decode",
    "base32/base64/base64url encode/decode",
    "md5, sha1, sha256, sha512, bcrypt",
    "camel, kebab, pascal, snake, slug, upper, lower, title",
    "count-lines, count-chars, count-words",
    "json-yaml, yaml-json, markdown-html",
    "extract-emails, extract-urls, extract-ip",
    "hex-encode/decode, hex-rgb",
    "url-encode/decode, html-encode/decode",
    "rot13, morse-encode/decode",
